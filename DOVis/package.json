{
  "name": "dovis",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm run --parallel \"/^dev:(backend|frontend)$/\"",
    "dev:backend": "python -m uvicorn backend.main:app --host 127.0.0.1 --port 5001",
    "dev:backend:reload": "python -m uvicorn backend.main:app --host 127.0.0.1 --port 5001 --reload --reload-dir backend",
    "dev:frontend": "pnpm --dir frontend dev --host 127.0.0.1",
    "setup": "pnpm run install:frontend && pnpm run install:backend",
    "install:frontend": "pnpm --dir frontend install",
    "install:backend": "python -m pip install -r requirements.txt",
    "build": "pnpm --dir frontend build",
    "lint": "pnpm --dir frontend lint"
  }
}
